#!/bin/bash

set -e

K8S_VERSION="1.29"

echo "=========================================="
echo " Kubernetes Universal Installer"
echo "=========================================="
echo

echo "Select node type:"
echo "1) MASTER"
echo "2) WORKER"
read -p "Enter choice (1 or 2): " NODETYPE

echo
echo "Preparing system..."

########################################
# Disable swap
########################################
sudo swapoff -a
sudo sed -i '/swap/d' /etc/fstab

########################################
# Kernel modules
########################################
sudo modprobe overlay
sudo modprobe br_netfilter

cat <<EOF | sudo tee /etc/modules-load.d/k8s.conf
overlay
br_netfilter
EOF

########################################
# Sysctl config
########################################
cat <<EOF | sudo tee /etc/sysctl.d/kubernetes.conf
net.bridge.bridge-nf-call-ip6tables = 1
net.bridge.bridge-nf-call-iptables = 1
net.ipv4.ip_forward = 1
EOF

sudo sysctl --system

########################################
# Install containerd
########################################
echo "Installing containerd..."

sudo yum install -y containerd

sudo mkdir -p /etc/containerd

sudo containerd config default | sudo tee /etc/containerd/config.toml >/dev/null

sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/' /etc/containerd/config.toml

sudo systemctl restart containerd
sudo systemctl enable containerd

########################################
# Install Kubernetes repo
########################################
echo "Installing Kubernetes packages..."

cat <<EOF | sudo tee /etc/yum.repos.d/kubernetes.repo
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/repodata/repomd.xml.key
EOF

sudo yum install -y kubelet kubeadm kubectl

sudo systemctl enable kubelet
sudo systemctl start kubelet

########################################
# MASTER INSTALL
########################################
if [ "$NODETYPE" == "1" ]; then

echo
echo "Initializing Kubernetes MASTER..."

sudo kubeadm init --pod-network-cidr=192.168.0.0/16

echo
echo "Configuring kubectl..."

mkdir -p $HOME/.kube
sudo cp /etc/kubernetes/admin.conf $HOME/.kube/config
sudo chown $(id -u):$(id -g) $HOME/.kube/config

echo
echo "Installing Calico network..."

kubectl apply -f https://docs.projectcalico.org/manifests/calico.yaml

echo
echo "=========================================="
echo "MASTER SETUP COMPLETE"
echo "=========================================="
echo
echo "Run this command on worker nodes:"
kubeadm token create --print-join-command

########################################
# WORKER INSTALL
########################################
elif [ "$NODETYPE" == "2" ]; then

echo
echo "=========================================="
echo "WORKER NODE READY"
echo "=========================================="
echo
echo "Run the join command provided by the master:"
echo
echo "sudo kubeadm join <MASTER-IP>:6443 --token <TOKEN> --discovery-token-ca-cert-hash sha256:<HASH>"
echo

else
echo "Invalid option"
exit 1
fi
